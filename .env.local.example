# Resend — get your key at resend.com/api-keys
# DO NOT prefix with VITE_ — this key must stay server-side only
RESEND_API_KEY=re_your_key_here

# Resend Audience ID — found in Resend dashboard > Audiences
RESEND_AUDIENCE_ID=your_audience_id_here

# Supabase (Phase D2)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary (Phase D4)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=unsigned-preset-name

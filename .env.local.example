# ─── Supabase ─────────────────────────────────────────────────────────────────
# Settings > API in your Supabase project dashboard

# Browser-safe (anon key — used in React app)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only — service role key (full DB access, NEVER expose to browser)
# Used by Vercel serverless functions (api/*.js)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Resend ────────────────────────────────────────────────────────────────────
# resend.com > API Keys (server-side only — no VITE_ prefix)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Resend > Audiences > your audience > ID
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# cloudinary.com > Dashboard > Cloud name
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# cloudinary.com > Settings > Upload > Add upload preset
# Set Mode = Unsigned, Folder = artworks (or mapheane)
VITE_CLOUDINARY_UPLOAD_PRESET=mapheane-unsigned

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# console.upstash.com > Create Database > REST API
# Required for rate limiting on contact/orders/track. Without these,
# rate limiting falls back to no-op (still works, just unprotected).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Deployment ───────────────────────────────────────────────────────────────
# Your production domain — restricts API CORS to this origin only
ALLOWED_ORIGIN=https://mapheane.art
